  "script": [
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "Your torchlight gutters against black water as you descend the last step. The air is cold and still, and something drips, far off in the dark. "
        },
        {
          "type": "cue",
          "kind": "image",
          "ref": "art/crypt.svg",
          "label": "🖼 art/crypt.svg"
        },
        {
          "type": "text",
          "text": " At the chamber's heart, a bone altar"
        },
        {
          "type": "cue",
          "kind": "sfx",
          "ref": "wight",
          "label": "🔊 wight"
        },
        {
          "type": "text",
          "text": " cradles a single violet gem that pulses like a slow heartbeat. "
        },
        {
          "type": "cue",
          "kind": "image",
          "ref": "art/altar.svg",
          "label": "🖼 art/altar.svg"
        },
        {
          "type": "text",
          "text": " As the first boot touches the water, the pulse quickens — and the dead sit up in their alcoves. "
        },
        {
          "type": "cue",
          "kind": "music",
          "ref": "rise",
          "label": "▶ rise"
        },
        {
          "type": "text",
          "text": " "
        },
        {
          "type": "cue",
          "kind": "sfx",
          "ref": "lib-deep-monster-roar",
          "label": "🔊 deep-monster-roar"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": []
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "cue",
          "kind": "sfx",
          "ref": "lib-deep-monster-roar",
          "label": "🔊 deep-monster-roar"
        }
      ]
    }
  ],
