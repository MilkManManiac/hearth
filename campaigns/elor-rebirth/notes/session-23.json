          "marks": [
            {
              "type": "bold"
            }
          ]
        },
        {
          "type": "text",
          "text": " in a meeting with the dwarven leaders. - "
        },
        {
          "type": "text",
          "text": "The deal held: daylight returned to ",
          "marks": [
            {
              "type": "bold"
            }
          ]
        },
        {
          "type": "link",
          "ref": "koviz"
        },
        {
          "type": "text",
          "text": " — ",
          "marks": [
            {
              "type": "bold"
            }
          ]
        },
        {
          "type": "link",
          "ref": "kennarea",
          "label": "Kennarea"
        },
        {
          "type": "text",
          "text": " honoring her side now that ",
          "marks": [
            {
              "type": "bold"
            }
          ]
        },
        {
          "type": "link",
          "ref": "root-darkpass",
          "label": "Root"
