  "ideas": [
    {
      "id": "idea-composition",
      "text": "The hangings are ARRANGED — sight-lines and spacing. Somebody stands here and enjoys it.",
      "done": false
    },
    {
      "id": "idea-rearranged",
      "text": "Some threads were cut and re-tied recently. The room has been rearranged, and not long ago.",
      "done": false
    },
    {
      "id": "idea-sound-map",
      "text": "Describe every enemy position by sound only; make players name the square they swing at",
      "done": false
    },
    {
      "id": "idea-silent-grab",
      "text": "The thing that grabs a PC makes no sound at all — no growl, no breath, just weight",
      "done": false
    },
    {
      "id": "idea-burn-tradeoff",
      "text": "Burning the gallery removes the obscurement — and then they can see the whole room, which is worse",
      "done": false
    },
    {
      "id": "idea-two-teeth",
      "text": "Two teeth tied to one thread — a child's and an adult's",
      "done": false
    }
  ],
  "entities": [
    {
      "id": "ent-gallery",
      "type": "hazard",
      "name": "The hanging gallery",
      "note": "Heavily obscured by OBJECTS — darkvision and light spells do nothing. Difficult terrain. Movement makes noise.",
      "status": "present",
      "used": false
    },
    {
      "id": "ent-keepsakes",
      "type": "prop",
      "name": "The keepsakes",
      "note": "Every object came off a person. Investigation DC 12. One find: a Ring of Protection on a thread (Investigation DC 15). Otherwise the payoff is the count.",
