  "ideas": [
    {
      "id": "idea-birdsong-loop",
      "text": "The birdsong is a loop — same calls, same positions. Perception catches it before anything moves.",
      "done": false
    },
    {
      "id": "idea-never-young",
      "text": "No saplings, no dead leaves, no seeds. The garden has never been young — it was made, not grown.",
      "done": false
    },
    {
      "id": "idea-offered-fruit",
      "text": "If the party is too careful, a branch bends down and offers fruit to the nearest PC",
      "done": false
    },
    {
      "id": "idea-second-lure",
      "text": "Badly wounded, it restarts the birdsong — sped up and wrong. Trying the lure again.",
      "done": false
    },
    {
      "id": "idea-pool-mouth",
      "text": "Restrained creatures get dragged toward the pool. The pool is the mouth.",
      "done": false
